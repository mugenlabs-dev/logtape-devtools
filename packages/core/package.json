{
  "name": "@mugenlabs/logtape-devtools",
  "version": "0.1.0",
  "description": "A TanStack DevTools plugin for inspecting LogTape logs in the browser",
  "keywords": [
    "logtape",
    "devtools",
    "logging",
    "tanstack",
    "react",
    "debugging"
  ],
  "homepage": "https://github.com/mugenlabs-dev/logtape-devtools",
  "bugs": {
    "url": "https://github.com/mugenlabs-dev/logtape-devtools/issues"
  },
  "license": "MIT",
  "author": "Yago Gonzalez",
  "repository": {
    "type": "git",
    "url": "https://github.com/mugenlabs-dev/logtape-devtools.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@logtape/logtape": "^2.0.4",
    "@storybook/react": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^10.2.19"
  },
  "peerDependencies": {
    "@logtape/logtape": ">=2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@tanstack/pacer": "^0.19.0"
  }
}
